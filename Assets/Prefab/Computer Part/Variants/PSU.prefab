    m_Modifications:
    - target: {fileID: -5151167579337538810, guid: 6927b257f3117f4418ec9c00f966a436,
        type: 3}
      propertyPath: partName
      value: PSU
      objectReference: {fileID: 0}
    - target: {fileID: -5151167579337538810, guid: 6927b257f3117f4418ec9c00f966a436,
