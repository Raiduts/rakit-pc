--- !u!1001 &6028880615805027496
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: -5151167579337538810, guid: 6927b257f3117f4418ec9c00f966a436,
        type: 3}
      propertyPath: partName
      value: CPU
      objectReference: {fileID: 0}
    - target: {fileID: -5151167579337538810, guid: 6927b257f3117f4418ec9c00f966a436,
        type: 3}
      propertyPath: multiplyer
      value: 10
      objectReference: {fileID: 0}
    - target: {fileID: -5151167579337538810, guid: 6927b257f3117f4418ec9c00f966a436,
        type: 3}
      propertyPath: description
      value: 'Prosesor atau CPU (Central Processing Unit) merupakan komponen utama
        yang berfungsi sebagai pusat pengolah data dan instruksi pada komputer. Semua
        aktivitas komputer seperti membuka aplikasi, menjalankan game, mengolah data,
        dan melakukan perhitungan diproses oleh CPU.


        Pada perakitan nanti
        digunakan AMD Ryzen 7 5700X3D. Prosesor ini dipilih karena memiliki performa
        tinggi dan kompatibel dengan motherboard ASUS Prime X570-P yang menggunakan
        socket AM4. Ryzen 7 5700X3D memiliki banyak core dan thread sehingga mampu
        menjalankan banyak tugas secara bersamaan dengan lancar. Teknologi 3D V-Cache
        yang dimiliki juga membantu meningkatkan performa terutama pada game dan
        aplikasi berat.


        Bagian penting prosesor:


        - Core: inti
        pemrosesan data

        - Thread: jalur kerja prosesor

        - Cache:
        memori kecil berkecepatan tinggi

        - Pin/contact: penghubung ke motherboard


        Prosesor
        harus dipasang dengan hati-hati karena memiliki posisi pemasangan tertentu
        yang harus sesuai dengan socket motherboard.'
      objectReference: {fileID: 0}
    - target: {fileID: -5151167579337538810, guid: 6927b257f3117f4418ec9c00f966a436,
        type: 3}
      propertyPath: partImageSprite
      value: 
      objectReference: {fileID: 21300000, guid: 327baa914a237cb4688c14417b40a86a,
        type: 3}
